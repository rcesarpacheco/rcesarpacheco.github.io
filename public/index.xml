    <item>
      <title>Teaching</title>
      <link>http://localhost:1313/teaching/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/teaching/</guid>
      <description>&lt;h3 id=&#34;instructor&#34;&gt;Instructor&lt;/h3&gt;&#xA;&lt;details class=&#34;ta-collapse&#34;&gt;&#xA;  &lt;summary class=&#34;ta-banner&#34;&gt;&#xA;    &lt;span class=&#34;ta-banner-text&#34;&gt;&#xA;      &lt;span class=&#34;ta-banner-title&#34;&gt;Intermediate Macroeconomics&lt;/span&gt;&#xA;      &lt;span class=&#34;ta-banner-score&#34;&gt;Columbia University · Summers 2024, 2025 · Evaluations: 4.9/5.0 (avg.)&lt;/span&gt;&#xA;    &lt;/span&gt;&#xA;    &lt;span class=&#34;ta-banner-arrow&#34;&gt;&lt;/span&gt;&#xA;  &lt;/summary&gt;&#xA;  &lt;div class=&#34;ta-collapse-body&#34;&gt;&#xA;    &lt;p class=&#34;paper-abstract&#34; style=&#34;margin-bottom: 0.8rem;&#34;&gt;Undergraduate course covering national income accounting, the classical closed-economy model, money and inflation, unemployment, the Solow growth model, economic fluctuations, the IS-LM model, and the aggregate supply curve and Phillips curve.&lt;/p&gt;&#xA;    &lt;div class=&#34;course-materials&#34;&gt;&#xA;      &lt;a href=&#34;http://localhost:1313/files/teaching/IntMacro_Syllabus_2025.pdf&#34;&gt;Syllabus&lt;/a&gt;&#xA;      &lt;a href=&#34;http://localhost:1313/files/teaching/evals/Pacheco_Summer_Teaching_Evaluations.pdf&#34;&gt;Teaching evaluations&lt;/a&gt;&#xA;      &lt;details class=&#34;slides-expand&#34;&gt;&#xA;        &lt;summary class=&#34;slides-toggle&#34;&gt;Lecture slides&lt;/summary&gt;&#xA;        &lt;div class=&#34;slides-list&#34;&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/01_Introduction.pdf&#34;&gt;Introduction&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/02_Data_of_Macroeconomics.pdf&#34;&gt;The Data of Macroeconomics&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/03_Closed_Economy_Model.pdf&#34;&gt;Closed Economy Model&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/04_Monetary_System.pdf&#34;&gt;Monetary System&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/05_Inflation.pdf&#34;&gt;Inflation&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/06_Unemployment.pdf&#34;&gt;Unemployment&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/07_Growth_Theory_I.pdf&#34;&gt;Growth Theory I&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/08_Growth_Theory_II.pdf&#34;&gt;Growth Theory II&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/09_Intro_Economic_Fluctuations.pdf&#34;&gt;Introduction to Economic Fluctuations&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/10_IS_LM_Model_I.pdf&#34;&gt;The IS-LM Model I&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/11_IS_LM_Model_II.pdf&#34;&gt;The IS-LM Model II&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/files/teaching/slides/12_AS_Curve_Phillips_Curve.pdf&#34;&gt;Aggregate Supply Curve and Phillips Curve&lt;/a&gt;&#xA;        &lt;/div&gt;&#xA;      &lt;/details&gt;&#xA;      &lt;details class=&#34;slides-expand&#34;&gt;&#xA;        &lt;summary class=&#34;slides-toggle&#34;&gt;Tools&lt;/summary&gt;&#xA;        &lt;div class=&#34;slides-list&#34;&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/Solow_ss_app/&#34; target=&#34;_blank&#34;&gt;Solow Steady State App&lt;/a&gt;&#xA;          &lt;a href=&#34;http://localhost:1313/solow_golden_rule_app/&#34; target=&#34;_blank&#34;&gt;Solow Golden Rule App&lt;/a&gt;&#xA;        &lt;/div&gt;&#xA;      &lt;/details&gt;&#xA;    &lt;/div&gt;&#xA;&lt;/details&gt;&#xA;&lt;h3 id=&#34;teaching-assistant&#34;&gt;Teaching assistant&lt;/h3&gt;&#xA;&lt;details class=&#34;ta-collapse&#34;&gt;&#xA;  &lt;summary class=&#34;ta-banner&#34;&gt;&#xA;    &lt;span class=&#34;ta-banner-text&#34;&gt;&#xA;      &lt;span class=&#34;ta-banner-title&#34;&gt;Columbia University&lt;/span&gt;&#xA;      &lt;span class=&#34;ta-banner-score&#34;&gt;Evaluations: 4.7/5.0 (avg.)&lt;/span&gt;&#xA;    &lt;/span&gt;&#xA;    &lt;span class=&#34;ta-banner-arrow&#34;&gt;&lt;/span&gt;&#xA;  &lt;/summary&gt;&#xA;  &lt;div class=&#34;ta-collapse-body&#34;&gt;&#xA;    &lt;table&gt;&#xA;      &lt;thead&gt;&lt;tr&gt;&lt;th&gt;Course&lt;/th&gt;&lt;th&gt;Semester&lt;/th&gt;&lt;th&gt;Evaluations&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&#xA;      &lt;tbody&gt;&#xA;        &lt;tr&gt;&lt;td&gt;Intermediate Macroeconomics (UG)&lt;/td&gt;&lt;td&gt;Fall 2022, Fall 2023, Spring 2024, Fall 2024, Spring 2025&lt;/td&gt;&lt;td&gt;&lt;a href=&#34;http://localhost:1313/files/teaching/evals/IntMacro_TA_Evals.pdf&#34; class=&#34;ta-eval-btn&#34;&gt;Download&lt;/a&gt;&lt;/td&gt;&lt;/tr&gt;&#xA;        &lt;tr&gt;&lt;td&gt;Advanced Macroeconomics (UG)&lt;/td&gt;&lt;td&gt;Fall 2025&lt;/td&gt;&lt;td&gt;&lt;a href=&#34;http://localhost:1313/files/teaching/evals/AdvMacro_TA_Evals.pdf&#34; class=&#34;ta-eval-btn&#34;&gt;Download&lt;/a&gt;&lt;/td&gt;&lt;/tr&gt;&#xA;        &lt;tr&gt;&lt;td&gt;Macroeconomic Analysis II (MA)&lt;/td&gt;&lt;td&gt;Spring 2023&lt;/td&gt;&lt;td&gt;&lt;a href=&#34;http://localhost:1313/files/teaching/evals/MacroAnalysis_TA_Evals.pdf&#34; class=&#34;ta-eval-btn&#34;&gt;Download&lt;/a&gt;&lt;/td&gt;&lt;/tr&gt;&#xA;      &lt;/tbody&gt;&#xA;    &lt;/table&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/details&gt;&#xA;&lt;details class=&#34;ta-collapse&#34;&gt;&#xA;  &lt;summary class=&#34;ta-banner&#34;&gt;&#xA;    &lt;span class=&#34;ta-banner-text&#34;&gt;&#xA;      &lt;span class=&#34;ta-banner-title&#34;&gt;University of São Paulo&lt;/span&gt;&#xA;    &lt;/span&gt;&#xA;    &lt;span class=&#34;ta-banner-arrow&#34;&gt;&lt;/span&gt;&#xA;  &lt;/summary&gt;&#xA;  &lt;div class=&#34;ta-collapse-body&#34;&gt;&#xA;    &lt;table&gt;&#xA;      &lt;thead&gt;&lt;tr&gt;&lt;th&gt;Course&lt;/th&gt;&lt;th&gt;Semester&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&#xA;      &lt;tbody&gt;&#xA;        &lt;tr&gt;&lt;td&gt;Macroeconomics IV (PhD)&lt;/td&gt;&lt;td&gt;2nd Sem. 2020&lt;/td&gt;&lt;/tr&gt;&#xA;        &lt;tr&gt;&lt;td&gt;Macroeconomics III (PhD)&lt;/td&gt;&lt;td&gt;2nd Sem. 2020&lt;/td&gt;&lt;/tr&gt;&#xA;        &lt;tr&gt;&lt;td&gt;Microeconomics II (PhD)&lt;/td&gt;&lt;td&gt;1st Sem. 2020&lt;/td&gt;&lt;/tr&gt;&#xA;        &lt;tr&gt;&lt;td&gt;Microeconomics I (PhD)&lt;/td&gt;&lt;td&gt;1st Sem. 2020&lt;/td&gt;&lt;/tr&gt;&#xA;        &lt;tr&gt;&lt;td&gt;Real Analysis (PhD)&lt;/td&gt;&lt;td&gt;Summer 2020&lt;/td&gt;&lt;/tr&gt;&#xA;        &lt;tr&gt;&lt;td&gt;Statistics (PhD)&lt;/td&gt;&lt;td&gt;Summer 2020&lt;/td&gt;&lt;/tr&gt;&#xA;      &lt;/tbody&gt;&#xA;    &lt;/table&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/details&gt;&#xA;&lt;h3 id=&#34;teaching-awards&#34;&gt;Teaching awards&lt;/h3&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;Wueller Teaching Award&lt;/strong&gt;, Columbia University, 2023&lt;/li&gt;&#xA;&lt;li&gt;&lt;strong&gt;Wueller Teaching Award, Runner-up&lt;/strong&gt;, Columbia University, 2024&lt;/li&gt;&#xA;&lt;/ul&gt;</description>
